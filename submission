Q9.
#!/bin/bash
time=$(date +%Y%m%d_%H%M%S)
file="report_$time.txt"
echo "System Report" > $file
echo "Date of report $(date)" >> $file
echo "" >> $file
echo "Uptime" >> $file
uptime >> $file
echo "" >> $file
echo "Memory Usage" >> $file
free -h >> $file
echo "" >> $file
echo "Disk Usage" >> $file
df -h >> $file
echo "" >> $file
echo "Top Process" >> $file
ps aux --sort=-%cpu | head -6 >> $file
echo "report saved in $file"

