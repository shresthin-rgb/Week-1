#!/bin/bash
echo "Enter a number"
read n
temp=$n
rev=0
while ((n>0))
do
r=$((n%10)) # reversing
rev=$((rev*10+r))
n=$((n/10))
done
if ((temp==rev))
then
echo "Is Palindrome"
else
echo "Not Palindrome"
fi

