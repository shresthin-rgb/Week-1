#!/bin/bash
echo "Enter a number"
read n
flag=0 # assuming number is prime
for ((i=2;i<n;i++))
do
if ((n%i==0))
then
flag=1
break
fi
done
if ((n<=1))
then
echo "Not Prime"
elif ((flag==0))
then
echo "Prime"
else
echo "Not Prime"
fi

